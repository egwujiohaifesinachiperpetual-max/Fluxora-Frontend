# ==============================================================================
# FLUXORA FRONTEND ENVIRONMENT VARIABLES CONFIGURATION (.env.example)
# ==============================================================================
# WARNING: SECURITY CONSIDERATIONS
# All variables starting with VITE_ are statically compiled into the client-side
# bundle by Vite. They are entirely public and visible to anyone inspecting the
# client application code in their browser.
# 
# DO NOT put sensitive secrets (e.g., private keys, wallet seed phrases, database
# passwords, session secrets, or private API keys) in this or any other frontend
# environment file.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Application Configurations
# ------------------------------------------------------------------------------

# VITE_API_URL (Optional)
# Purpose: Base URL for the Fluxora backend API service.
# Status: Optional. If left blank, API integrations may fallback or run in mock mode.
# Format: Absolute HTTP/HTTPS URL (must include protocol).
# Example: VITE_API_URL=https://api.fluxora.example.com
VITE_API_URL=

# VITE_NETWORK (Optional, Defaults to 'TESTNET')
# Purpose: Stellar network that the frontend expects connected wallet actions to use.
# Status: Optional. Missing or unsupported values fail closed/default to 'TESTNET'.
# Format: String matching network enum: 'PUBLIC' (Mainnet) or 'TESTNET'.
# Example: VITE_NETWORK=TESTNET
VITE_NETWORK=TESTNET

# VITE_RPC_URL (Optional, Required for live transactions)
# Purpose: Soroban RPC server endpoint URL for submitting and simulating smart contract actions.
# Status: Optional at build time, but required at runtime for live Stellar/Soroban wallet operations.
# Format: Absolute HTTP/HTTPS URL (must include protocol).
# Example: VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_RPC_URL=

# VITE_STREAM_CONTRACT_ID (Optional, Required for live transactions)
# Purpose: Smart contract address of the deployed Fluxora treasury streaming protocol.
# Status: Optional at build time, but required at runtime to interact with the streaming contract.
# Format: Stellar Contract ID (starts with 'C', followed by 55 alphanumeric uppercase characters).
# Example: VITE_STREAM_CONTRACT_ID=CBQQXQSQB4GBB5XDPBFWEXTURY5HDG37TIE7YZ3WHP3DXVZQ2E4UHY4Z
VITE_STREAM_CONTRACT_ID=

# VITE_USE_MOCKS (Optional, Defaults to 'false')
# Purpose: Toggle switch to enable client-side mocks for API endpoints and contracts.
# Status: Optional. Defaults to false.
# Format: Boolean-equivalent string: 'true' or '1' resolves to true; any other value resolves to false.
# Example: VITE_USE_MOCKS=true
VITE_USE_MOCKS=true

# ------------------------------------------------------------------------------
# Development & Testing Configs
# ------------------------------------------------------------------------------

# VITE_DEMO_MODE (Optional, Defaults to 'false')
# Purpose: Toggle to render static treasury overview dashboard mock data.
# Status: Optional. Useful for tests, previews, or screenshots without active wallet connections.
# Format: Boolean-equivalent string: 'true' or '1' resolves to true; any other value resolves to false.
# Example: VITE_DEMO_MODE=false
VITE_DEMO_MODE=false

# ------------------------------------------------------------------------------
# Transaction Polling Settings (Client timing controls)
# ------------------------------------------------------------------------------

# VITE_TX_POLL_INTERVAL_MS (Optional, Defaults to '750')
# Purpose: Polling interval in milliseconds between checks for Stellar/Soroban transaction completion.
# Status: Optional.
# Format: Positive integer greater than or equal to 1.
# Example: VITE_TX_POLL_INTERVAL_MS=750
VITE_TX_POLL_INTERVAL_MS=750

# VITE_TX_POLL_MAX_ATTEMPTS (Optional, Defaults to '6')
# Purpose: Maximum number of status-check polling attempts before marking the transaction as failed.
# Status: Optional.
# Format: Positive integer greater than or equal to 1.
# Example: VITE_TX_POLL_MAX_ATTEMPTS=6
VITE_TX_POLL_MAX_ATTEMPTS=6

# VITE_TX_POLL_BACKOFF_FACTOR (Optional, Defaults to '1.25')
# Purpose: Exponential multiplier applied to the poll interval on subsequent transaction-status check attempts.
# Status: Optional.
# Format: Positive floating-point number greater than or equal to 1.0.
# Example: VITE_TX_POLL_BACKOFF_FACTOR=1.25
VITE_TX_POLL_BACKOFF_FACTOR=1.25

# VITE_TX_DEMO_CONFIRMATION_ATTEMPTS (Optional, Defaults to '2')
# Purpose: Number of simulated confirmation cycles before mock transactions succeed in demo mode.
# Status: Optional.
# Format: Positive integer greater than or equal to 1.
# Example: VITE_TX_DEMO_CONFIRMATION_ATTEMPTS=2
VITE_TX_DEMO_CONFIRMATION_ATTEMPTS=2

# ------------------------------------------------------------------------------
# Additional runtime tuning
# ------------------------------------------------------------------------------
VITE_TX_BASE_FEE=100
# How often (ms) the wallet watcher polls Freighter for changes. Default: 2000.
# Must be >= 500 ms. Increase on slow networks or in CI.
VITE_WALLET_WATCH_INTERVAL_MS=
