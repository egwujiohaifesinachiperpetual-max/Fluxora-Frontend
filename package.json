{
  "name": "fluxora-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:report": "vite build && node scripts/bundle-size-report.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,json,md}\" --write",
    "format:check": "prettier eslint.config.js .prettierrc package.json --check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test accessibility",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "@tailwindcss/vite": "^4.2.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "1.61.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fast-check": "^4.8.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  }
}
